{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/cron/auto-fetch",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/cron/daily-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/cron/follow-up-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
