PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (used for all tasks unless overridden below)
# Options: claude | openai | gemini | ollama | mock
AI_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Per-task model overrides (all Gemini; leave blank to use AI_PROVIDER default)
# gemini-2.5-flash-lite is ~10x cheaper than Claude Haiku and recommended for both tasks
SCORING_AI_MODEL=gemini-2.5-flash-lite
COMPANY_AI_MODEL=gemini-2.5-flash-lite

# AI behavior
AI_REQUEST_DELAY_HOURS=24
# JOB_DESCRIPTION_MAX_CHARS=    # truncate job descriptions before scoring; unset = no truncation

# Multi-provider consensus (Phase 7, comma-separated)
# AI_PROVIDERS=claude,openai

# Job source APIs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Email notifications (Resend)
RESEND_API_KEY=
CRON_SECRET=your-cron-secret
EMAIL_FROM=
EMAIL_FROM_NAME=
