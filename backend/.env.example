PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI providers (set AI_PROVIDER to switch)
# Options: claude | openai | gemini | ollama | mock
AI_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434

# Cheaper model for company research (Gemini only). gemini-2.0-flash-lite recommended.
COMPANY_AI_MODEL=gemini-2.0-flash-lite

# Hours before a scored job can be re-scored. Low values (e.g. 0.1) for dev/testing.
RESCORE_DELAY_HOURS=24

# Multi-provider consensus (Phase 7, comma-separated)
# AI_PROVIDERS=claude,openai

# Job source APIs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
